# ─── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
APP_ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=rezeb
POSTGRES_USER=rezeb
POSTGRES_PASSWORD=rezeb_dev_password
DATABASE_URL=postgresql+asyncpg://rezeb:rezeb_dev_password@postgres:5432/rezeb

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_QUEUE_URL=redis://redis:6379/1

# ─── S3 / Object Storage ───────────────────────────────────────────────────────
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_PHOTOS=rezeb-photos
S3_BUCKET_DOCS=rezeb-docs
S3_REGION=ru-central1

# ─── AITUNNEL (LLM/Embeddings API) ────────────────────────────────────────────
AITUNNEL_BASE_URL=https://api.aitunnel.ru/v1
AITUNNEL_API_KEY=your-aitunnel-api-key-here

# Claude models
MODEL_VISION=claude-sonnet-4-6
MODEL_COMPLEX=claude-opus-4-7
MODEL_FAST=claude-haiku-4-5-20251001
MODEL_EMBEDDINGS=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072

# ─── ML / GPU inference ────────────────────────────────────────────────────────
ML_SERVICE_URL=http://ml-service:8001
YOLO_MODEL_PATH=/models/yolov11_construction.onnx
YOLO_CONFIDENCE_THRESHOLD=0.45
ESCALATION_CONFIDENCE_THRESHOLD=0.70

# ─── Auth / JWT ────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_USER=60
RATE_LIMIT_WINDOW_SECONDS=60

# ─── LLM Cost Limits (per user per day) ───────────────────────────────────────
DAILY_CONTROL_LIMIT_PER_USER=50
DAILY_PTO_LIMIT_PER_USER=200
MONTHLY_LLM_BUDGET_RUB=30000
BUDGET_ALERT_THRESHOLD=0.80

# ─── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── Telegram alerts ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
